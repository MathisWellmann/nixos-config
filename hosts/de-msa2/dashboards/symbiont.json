      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (rate(symbiont_revision_activations_total{model=~\"$model\",instance=~\"$instance\"}[$__rate_interval])) * 3600", "legendFormat": "{{instance}}", "refId": "A" } ],
      "title": "Revision activations / h by instance",
      "type": "timeseries"
