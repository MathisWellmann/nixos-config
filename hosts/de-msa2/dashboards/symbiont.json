      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (kind) (rate(symbiont_evolve_failures_total{model=~\"$model\",instance=~\"$instance\"}[$__rate_interval])) * 3600", "legendFormat": "{{kind}}", "refId": "A" } ],
      "title": "Evolve failures / h by kind",
