      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(symbiont_llm_runs_total{model=~\"$model\",instance=~\"$instance\"}[$__rate_interval])) * 3600", "legendFormat": "runs/h", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(symbiont_llm_runs_total{model=~\"$model\",instance=~\"$instance\"}[15m])) * 3600", "legendFormat": "runs/h (15m avg)", "refId": "B" }
