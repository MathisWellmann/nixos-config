  "description": "agent-symbiont fleet: self-evolving binaries reporting evolution pipeline health, LLM token consumption and revision registry state. Designed for many concurrent instances -- filter via the model/instance variables; all timeseries break down per instance. Summary quantiles are unpopulated (report 0), so means are derived from _sum/_count rates.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["symbiont"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(symbiont_revisions_loaded, model)",
