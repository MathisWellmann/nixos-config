      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (stage) (rate(symbiont_pipeline_stage_duration_seconds_sum{model=~\"$model\",instance=~\"$instance\"}[$__rate_interval])) / sum by (stage) (rate(symbiont_pipeline_stage_duration_seconds_count{model=~\"$model\",instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{stage}}", "refId": "A" } ],
      "title": "Mean stage duration",
