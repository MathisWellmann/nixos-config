      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (rate(symbiont_evolve_duration_seconds_sum{model=~\"$model\",instance=~\"$instance\"}[$__rate_interval])) / sum by (instance) (rate(symbiont_evolve_duration_seconds_count{model=~\"$model\",instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{instance}}", "refId": "A" } ],
