      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(tikr_iggy_sink_messages_consumed{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "consumed/s", "refId": "A" } ],
      "title": "Sink consume rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "WebSocket messages received per second across all producers (raw exchange ingest).",
