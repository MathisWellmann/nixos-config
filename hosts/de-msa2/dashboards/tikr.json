      "title": "Producer ingest rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "p99 ClickHouse insert latency across sinks. High values (hundreds of ms) reflect the per-INSERT HTTP round-trip cost.",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "µs", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 500000 }, { "color": "red", "value": 2000000 } ] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(tikr_clickhouse_insert_latency_micros_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "A" } ],
